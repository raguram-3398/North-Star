digraph NorthStarArchitecture {
  rankdir=TB;
  fontname="Helvetica";
  labelloc="t";
  fontsize=20;
  label="Project North Star — Component Architecture\n(box color = reasoning/generation vs. deterministic vs. skill vs. external vs. cron vs. HITL gate)";
  splines=true;
  concentrate=true;
  nodesep=0.45;
  ranksep=0.55;

  node [fontname="Helvetica", fontsize=11, style="filled", shape="box"];
  edge [fontname="Helvetica", fontsize=9, color="#555555"];

  /* ---------- Legend ---------- */
  subgraph cluster_legend {
    label="Legend";
    style="dashed";
    fontsize=11;
    color="#999999";
    legend_agent   [label="Reasoning / Generation\n(Agent)", fillcolor="#cfe2ff"];
    legend_det     [label="Deterministic\n(plain, testable module)", fillcolor="#d9f2d9"];
    legend_skill   [label="Agent Skill\n(schema-validated, LLM-backed)", fillcolor="#e6d9f2"];
    legend_ext     [label="External Service", fillcolor="#fff2cc"];
    legend_cron    [label="Cron / Scheduled Trigger\n(not an agent)", fillcolor="#f0f0f0"];
    legend_gate    [label="HITL Checkpoint\n(user-facing gate)", fillcolor="#ffe0b3"];
    legend_agent -> legend_det -> legend_skill -> legend_ext -> legend_cron -> legend_gate [style=invis];
  }

  /* ---------- Cron ---------- */
  subgraph cluster_cron {
    label="Cron / Scheduled Refresh (deterministic trigger, not agentic)";
    style="filled,dashed";
    color="#888888";
    fillcolor="#f7f7f7";
    fontsize=12;
    gh_action     [label="GitHub Actions\nscheduled workflow\n(refresh_roles.yml)", fillcolor="#f0f0f0"];
    startup_check [label="Streamlit startup\nstaleness check", fillcolor="#f0f0f0"];
    refresh_fn    [label="cron/refresh_roles.py\n(shared refresh function)", fillcolor="#f0f0f0"];
    gh_action -> refresh_fn     [label="wall-clock trigger\n(>= every 30 days)"];
    startup_check -> refresh_fn [label="on stale roles_cache\nat session start"];
  }

  /* ---------- Agent 1 ---------- */
  subgraph cluster_agent1 {
    label="Agent 1 — Research & Outline Agent\n(owns: clarify-gate question content, cross-validation judgment, initial hierarchy creation)";
    style="filled,bold";
    color="#3366cc";
    fillcolor="#eaf1ff";
    fontsize=12;
    agent1 [label="Research & Outline Agent\n(reasoning / generation)", fillcolor="#cfe2ff", penwidth=2];
  }

  /* ---------- Agent 1's deterministic tools + its external data sources ---------- */
  subgraph cluster_det1 {
    label="Deterministic tools — Agent 1";
    style="filled";
    color="#339933";
    fillcolor="#f2fbf2";
    fontsize=12;
    input_gate      [label="security/input_gate.py\n(clarify-gate bound/loop\nstate, reject detection)", fillcolor="#d9f2d9"];
    output_guard    [label="security/output_guard.py\n(confidence-ladder +\nsource validation gate)", fillcolor="#d9f2d9"];
    hierarchy       [label="outline/hierarchy.py\n(insert into existing\ndependency structure)", fillcolor="#d9f2d9"];
    significant_evt [label="outline/significant_event.py\n(bucket/confidence\ncrossing diff)", fillcolor="#d9f2d9"];
    patch_manager   [label="patches/patch_manager.py\n(confidence branching,\ndelivery ordering)", fillcolor="#d9f2d9"];
    roles_cache_io  [label="data/roles_cache.py\n(I/O)", fillcolor="#d9f2d9"];
  }

  subgraph cluster_ext1 {
    label="Market data sources (Agent 1)";
    style="filled";
    color="#b38f00";
    fillcolor="#fffaeb";
    fontsize=12;
    himalayas [label="Himalayas MCP\n(structured market data)", fillcolor="#fff2cc", shape=ellipse];
    tavily    [label="Tavily\n(web search)", fillcolor="#fff2cc", shape=ellipse];
  }

  neon [label="Neon Postgres\n(persistence)", fillcolor="#fff2cc", shape=cylinder, style=filled];

  /* ---------- HITL checkpoint ---------- */
  outline_confirmation [label="Outline Confirmation\n(HITL checkpoint — PRD §7.5)\nbounded loop, pre-Day-1 only", shape=diamond, fillcolor="#ffe0b3", fontsize=11];

  /* ---------- Agent 2 ---------- */
  subgraph cluster_agent2 {
    label="Agent 2 — Coaching & Pace Agent\n(owns: day-by-day content generation, goal-completion closing note)";
    style="filled,bold";
    color="#3366cc";
    fillcolor="#eaf1ff";
    fontsize=12;
    agent2 [label="Coaching & Pace Agent\n(reasoning / generation)", fillcolor="#cfe2ff", penwidth=2];
  }

  /* ---------- Agent 2's deterministic tools + skill ---------- */
  subgraph cluster_det2 {
    label="Deterministic tools — Agent 2";
    style="filled";
    color="#339933";
    fillcolor="#f2fbf2";
    fontsize=12;
    pace_calc       [label="pace/calculator.py\n(topic_score, timing_ratio,\n80/20 blend, drift check)", fillcolor="#d9f2d9"];
    progress_log_io [label="data/progress_log.py\n(I/O)", fillcolor="#d9f2d9"];
  }

  subgraph cluster_skill {
    label="Agent Skill (.agent/skills/)";
    style="filled";
    color="#7a4fa3";
    fillcolor="#f5f0fa";
    fontsize=12;
    verification_skill [label="Verification Question\nGenerator Skill\n(source material in →\n5 questions + rubric out)", fillcolor="#e6d9f2"];
  }

  gemini [label="Gemini\n(LLM, via ADK)", fillcolor="#fff2cc", shape=ellipse, style=filled];

  /* ================= Cron -> Agent 1 ================= */
  refresh_fn -> agent1        [label="invokes Research/Grounding\npipeline (seed role list)", style=dashed];
  refresh_fn -> roles_cache_io [label="writes refreshed data"];

  /* ================= Agent 1 pipeline ================= */
  agent1 -> input_gate       [label="raw user input"];
  agent1 -> hierarchy        [label="new/updated topic"];
  agent1 -> significant_evt  [label="old vs. new snapshot"];
  agent1 -> patch_manager    [label="confidence tier"];
  agent1 -> roles_cache_io   [label="read (anchor) /\nwrite (bootstrap)"];
  agent1 -> himalayas        [label="market data query"];
  agent1 -> tavily           [label="search query"];
  agent1 -> output_guard     [label="candidate outline item /\ngrounding result"];
  agent1 -> gemini           [label="clarify-gate + outline\nreasoning calls", constraint=false];

  output_guard -> neon       [label="validated write only\n(gated)", color="#3366cc", penwidth=1.5];
  roles_cache_io -> neon     [label="read / write"];

  neon -> outline_confirmation [label="grounded outline\nshown for review"];
  outline_confirmation -> agent2 [label="confirmed (or bound exhausted) → Day 1 begins\nAgent 2 reads only by (user_id, topic_id) reference\n— never raw Agent 1 output", style=dashed, color="#cc8400", penwidth=1.5];

  /* ================= Agent 2 pipeline ================= */
  agent2 -> pace_calc          [label="per-question credit,\ntiming data"];
  agent2 -> progress_log_io    [label="read / write"];
  agent2 -> verification_skill [label="topic source material,\n# questions needed"];
  agent2 -> roles_cache_io     [label="read-only\n(closing note, enrichment)", constraint=false];
  agent2 -> gemini             [label="day content + closing-note\ngeneration calls", constraint=false];

  verification_skill -> gemini [label="question generation", constraint=false];
  progress_log_io -> neon;
}
